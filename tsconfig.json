{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "DOM",
      "ES2017"
    ],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmitOnError": false,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "js/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}